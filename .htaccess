# Stargroup Tracker Link
DirectoryIndex index.php

# Don't expose internal config files
<FilesMatch "^(bootstrap\.php|config\.php)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Allow tracker endpoint to be called from anywhere (CORS handled in PHP)
<Files "track.php">
    <IfModule mod_authz_core.c>
        Require all granted
    </IfModule>
</Files>
<Files "t.php">
    <IfModule mod_authz_core.c>
        Require all granted
    </IfModule>
</Files>
